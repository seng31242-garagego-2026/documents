<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/148.0.0.0 Safari/537.36" version="29.3.6">
  <diagram name="Page-1" id="p3D9Sk2QAGIG2tVIEfOP">
    <mxGraphModel dx="2450" dy="1293" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\n&#39; --- Changed to Vertical Alignment to Minimize Width ---\ntop to bottom direction\nskinparam handwritten false\nskinparam shadowranking false\nskinparam padding 6\nskinparam roundcorner 10\n\n&#39; --- Fixed Global Styles ---\nskinparam package {\n    BackgroundColor #F8FAFC\n    BorderColor #CBD5E1\n    FontColor #475569\n    FontSize 13\n    FontStyle bold\n}\n\n&#39; --- Supported Stereotype Styling Engines ---\nskinparam rectangle&lt;&lt;Customer&gt;&gt; {\n    BackgroundColor #E0F2FE\n    BorderColor #0284C7\n    FontColor #0369A1\n    BorderThickness 2\n}\n\nskinparam rectangle&lt;&lt;Garage&gt;&gt; {\n    BackgroundColor #DCFCE7\n    BorderColor #16A34A\n    FontColor #15803D\n    BorderThickness 2\n}\n\nskinparam rectangle&lt;&lt;Mechanic&gt;&gt; {\n    BackgroundColor #FEF9C3\n    BorderColor #CA8A04\n    FontColor #A16207\n    BorderThickness 2\n}\n\n&#39; =========================================================================\n&#39; 1. CUSTOMER MOBILE APP (Stacked Bottom-to-Top)\n&#39; =========================================================================\npackage \&quot;Customer Mobile App\&quot; as pkg_customer {\n    rectangle \&quot;C1: Enter Name\&quot; as C1 &lt;&lt;Customer&gt;&gt;\n    rectangle \&quot;C2: Phone / Twilio OTP\&quot; as C2 &lt;&lt;Customer&gt;&gt;\n    rectangle \&quot;C3: Set Password\&quot; as C3 &lt;&lt;Customer&gt;&gt;\n    rectangle \&quot;C4: JWT Session Dashboard\&quot; as C4 &lt;&lt;Customer&gt;&gt;\n    rectangle \&quot;C11: Live Map Tracking\&quot; as C11 &lt;&lt;Customer&gt;&gt;\n    rectangle \&quot;C9: Long Press SOS (3s)\&quot; as C9 &lt;&lt;Customer&gt;&gt;\n    rectangle \&quot;C5: Search &amp; Filter Garages\&quot; as C5 &lt;&lt;Customer&gt;&gt;\n    rectangle \&quot;C6: View Garage Profile\&quot; as C6 &lt;&lt;Customer&gt;&gt;\n    rectangle \&quot;C7: Select Service &amp; Date\&quot; as C7 &lt;&lt;Customer&gt;&gt;\n    rectangle \&quot;C10: Select Vehicle &amp; Issue\&quot; as C10 &lt;&lt;Customer&gt;&gt;\n    rectangle \&quot;C8: Booking Placed Container\&quot; as C8 &lt;&lt;Customer&gt;&gt;\n\n    C1 -up-&gt; C2\n    C2 -up-&gt; C3\n    C3 -up-&gt; C4\n    C4 -up-&gt; C11\n    C11 -up-&gt; C9\n    C9 -up-&gt; C5\n    C5 -up-&gt; C6\n    C6 -up-&gt; C7\n    C7 -up-&gt; C10\n    C10 -up-&gt; C8\n}\n\n&#39; =========================================================================\n&#39; 2. GARAGE OWNER WEB PORTAL (Positioned below Customer block)\n&#39; =========================================================================\npackage \&quot;Garage Owner Web Portal\&quot; as pkg_garage {\n    rectangle \&quot;G3: Accept or Reject Booking\&quot; as G3 &lt;&lt;Garage&gt;&gt;\n    rectangle \&quot;G6: Create Itemized Invoice\&quot; as G6 &lt;&lt;Garage&gt;&gt;\n    rectangle \&quot;G7: Confirm Cash Receipt\&quot; as G7 &lt;&lt;Garage&gt;&gt;\n    rectangle \&quot;G5: Live Map &amp; Dispatcher\&quot; as G5 &lt;&lt;Garage&gt;&gt;\n    rectangle \&quot;G8: Close Booking Ledger\&quot; as G8 &lt;&lt;Garage&gt;&gt;\n    rectangle \&quot;G1: Live Dashboard Overview\&quot; as G1 &lt;&lt;Garage&gt;&gt;\n    rectangle \&quot;G4: SOS Alerts Broadcast Radar\&quot; as G4 &lt;&lt;Garage&gt;&gt;\n    rectangle \&quot;G2: Incoming Requests Panel\&quot; as G2 &lt;&lt;Garage&gt;&gt;\n\n    G3 -up-&gt; G6\n    G6 -up-&gt; G7\n    G7 -up-&gt; G5\n    G5 -up-&gt; G8\n    G8 -up-&gt; G1\n    G1 -up-&gt; G4\n    G4 -up-&gt; G2\n}\n\n&#39; =========================================================================\n&#39; 3. MECHANIC MOBILE APP (Spatially isolated at the base)\n&#39; =========================================================================\npackage \&quot;Mechanic Mobile App\&quot; as pkg_mechanic {\n    rectangle \&quot;M1: Garage-Credential Login\&quot; as M1 &lt;&lt;Mechanic&gt;&gt;\n    rectangle \&quot;M2: Assignment Notification\&quot; as M2 &lt;&lt;Mechanic&gt;&gt;\n    rectangle \&quot;M6: Complete Job (Notes/Photos)\&quot; as M6 &lt;&lt;Mechanic&gt;&gt;\n    rectangle \&quot;M3: Map Navigation Route\&quot; as M3 &lt;&lt;Mechanic&gt;&gt;\n    rectangle \&quot;M4: Toggle Status (Arrived)\&quot; as M4 &lt;&lt;Mechanic&gt;&gt;\n    rectangle \&quot;M5: Work Progress Flag\&quot; as M5 &lt;&lt;Mechanic&gt;&gt;\n\n    M1 -up-&gt; M2\n    M2 -up-&gt; M6\n    M6 -up-&gt; M3\n    M3 -up-&gt; M4\n    M4 -up-&gt; M5\n}\n\n&#39; =========================================================================\n&#39; CROSS-CONTAINER SHORTER VERTICAL INTERCONNECTIONS\n&#39; =========================================================================\nC8 -down-&gt; G2 : \&quot;FCM Alert\&quot;\nC10 -down-&gt; G4 : \&quot;Socket.io Broadcast\&quot;\nG8 -up-&gt; C4 : \&quot;Clear Outstanding Balance\&quot;\nG5 -up-&gt; C11 : \&quot;Stream GPS Coordinates\&quot;\n\nG3 -down-&gt; M2 : \&quot;Dispatch Mechanic\&quot;\n\nM3 -up-&gt; G5 : \&quot;Live GPS Stream\&quot;\nM6 -up-&gt; G6 : \&quot;Populate Repair Data\&quot;\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="sTNQbczQpGJB4HnXUh30-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="2266" width="981" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
