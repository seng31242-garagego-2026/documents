    <mxGraphModel dx="1873" dy="1022" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle UC-21 Admin Approve Garage - Activity Diagram\n\n|Garage Owner|\nstart\n:Submit Garage Registration;\n\n|System|\n:Store Registration as Pending;\n\n|Admin|\n:Open Pending Garage Applications;\n:Review Business Information;\n:Verify Documents and Registration Details;\n\nwhile (Information Complete?) is (No)\n\n  :Request Additional Information;\n\n  |System|\n  :Notify Garage Owner;\n\n  |Garage Owner|\n  :Submit Missing Information;\n\n  |Admin|\n  :Review Updated Information;\n\nendwhile (Yes)\n\nif (Registration Valid?) then (Yes)\n\n  :Approve Garage;\n\n  |System|\n  :Update Garage Status to Approved;\n  :Make Garage Visible to Customers;\n  :Send Approval Notification to Garage Owner;\n\nelse (No)\n\n  :Reject Application;\n\n  |System|\n  :Send Rejection Notification to Garage Owner;\n\nendif\n\nstop\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="M-fGmOLdKBXzaMl7J5_A-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="997" width="1145" x="40" y="40" as="geometry" />
          </mxCell>
