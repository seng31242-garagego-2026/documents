        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nactor Customer\nparticipant \&quot;Mobile App\&quot; as App\nparticipant \&quot;Backend API\&quot; as API\nparticipant \&quot;Twilio API\&quot; as Twilio\nparticipant \&quot;Email Service\&quot; as Email\ndatabase \&quot;PostgreSQL DB\&quot; as DB\n\nCustomer -&gt; App : Open Registration\nCustomer -&gt; App : Enter User Details\n\nApp -&gt; API : Send Registration Data\nAPI -&gt; Twilio : Send OTP SMS\nTwilio --&gt; Customer : OTP Code\n\nCustomer -&gt; App : Enter OTP\nApp -&gt; API : Verify OTP\n\nAPI -&gt; Email : Send Verification Email\nEmail --&gt; Customer : Verification Link\n\nCustomer -&gt; App : Verify Email\nApp -&gt; API : Confirm Verification\n\nAPI -&gt; DB : Create User Account\nDB --&gt; API : Success\n\nAPI --&gt; App : Registration Successful\nApp --&gt; Customer : Account Created\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="BA_HEjSR0701TqfNBTy4-1">
