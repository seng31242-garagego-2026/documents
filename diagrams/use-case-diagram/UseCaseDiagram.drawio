  <diagram id="jZXtHCHssJ9qiYh23U8H" name="Page-3">
    <mxGraphModel dx="2138" dy="1803" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle UC-06 Emergency SOS Dispatch - Activity Diagram\n\n|Customer|\nstart\n:Press SOS Button;\n\n|System|\n:Request GPS Location;\n\n|Google Maps API|\n:Provide GPS Coordinates;\n\n|System|\n:Capture Current Location;\n\n|Customer|\n:Select Vehicle;\n:Enter Issue Description;\n\n|System|\n:Identify Nearby Approved Garages;\n:Filter Garages by Coverage and Availability;\n:Broadcast Emergency Alert;\n:Start 60-Second Acceptance Timer;\n\nwhile (Garage Accepted?) is (No)\n\n  :Expand Search Radius;\n  :Retry Emergency Broadcast;\n\nendwhile (Yes)\n\n:System Assigns Emergency to First Accepted Garage;\n\n|Garage Owner|\n:Review Emergency Details;\n:Select Available Mechanic;\n\n|Mechanic|\n:Receive Assignment Notification;\n:Open Navigation;\n:Travel to Customer Location;\n:Send Live GPS Updates;\n\n|Customer|\n:Track Mechanic in Real Time;\n\n|Mechanic|\n:Mark Arrival;\n:Perform Repair;\n:Mark Repair Complete;\n\n|System|\n:Update Emergency Status to Completed;\n\nstop\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="xLrIU2s-AuTyNRehjDtY-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1501" width="1116" x="-70" y="-60" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="ZICgRzhjNdFcj0VLsa4K" name="Page-6">
    <mxGraphModel dx="2060" dy="1124" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle UC-15 Accept Emergency SOS - Activity Diagram\n\n|System|\nstart\n:Broadcast emergency SOS alert;\n\n|Garage Owner|\n:Receive emergency request;\n:Review customer location and issue;\n\nif (Accept emergency?) then (Yes)\n\n  |System|\n  :Check if already assigned;\n\n  if (Already assigned?) then (Yes)\n    :Display \&quot;Assignment Unavailable\&quot;;\n\n    stop\n  else (No)\n    :Lock assignment;\n\n    |Garage Owner|\n    :Select available mechanic;\n\n    |Mechanic|\n    :Receive assignment notification;\n    :Open navigation;\n\n    :Travel to customer location;\n\n    |System|\n    :Enable live GPS tracking;\n\n    |Mechanic|\n    :Send live GPS updates;\n\n    |Customer|\n    :Track mechanic location;\n\n    |Mechanic|\n    :Mark arrival;\n    :Perform repair;\n    :Mark repair complete;\n\n    |System|\n    :Update emergency status to COMPLETED;\n\n    stop\n  endif\n\nelse (No)\n\n  :Ignore request;\n  stop\n\nendif\n\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="nBa-IkSmvpH_Cf1UtBD2-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1110" width="1276" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="SGJLbYCSx1uqFDkaXGNj" name="Page-4">
    <mxGraphModel dx="2060" dy="1124" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle UC-04 Book Scheduled Service - Activity Diagram\n\n|Customer|\nstart\n:Search Garages;\n:Select Garage;\n:Select Vehicle;\n:Choose Service Type;\n:Select Preferred Date and Time;\n\n|System|\n:Check Garage Capacity and Availability;\n\nwhile (Capacity Available?) is (No)\n\n  :Suggest Another Slot;\n\n  |Customer|\n  :Select Different Date/Time;\n\n  |System|\n  :Recheck Capacity and Availability;\n\nendwhile (Yes)\n\n:System Estimates Service Cost;\n\n\n|System|\n:Create Booking Request;\n\n|Customer|\n  :Confirm Booking;\n\n|Garage Owner|\n:Receive Booking Request;\n\n|System|\n:Start 2-Hour Response Timer;\n\nif (Garage Accepts Booking?) then (Yes)\n\n  :Confirm Booking;\n  :Notify Customer;\n\nelse (No)\n\n  :Reject Booking;\n  :Notify Customer;\n\nendif\n\nstop\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="iNzrNJ2IWKlZWdMMq7RA-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1132" width="705" x="232" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="QqeL7v9GfxUMKr-KRRVa" name="Page-7">
    <mxGraphModel dx="4120" dy="2248" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle UC-05 Cancel Booking (Penalty-Based System)\n\n|Customer|\nstart\n:Open booking details;\n:Select \&quot;Cancel Booking\&quot;;\n\n|System|\n:Check booking status;\n:Evaluate cancellation policy;\n\nif (Cancellation allowed?) then (Yes)\n\n  :Check booking acceptance status;\n\n  if (Booking already accepted?) then (Yes)\n    :Calculate cancellation penalty fee;\n    :Apply penalty to customer account;\n    :Store penalty record for future bookings;\n\n  else (No)\n    :No penalty applied;\n  endif\n\n  :Update customer profile with cancellation history;\n  :Mark customer as \&quot;Penalty Flagged\&quot; if applicable;\n\n  |Garage Owner|\n  :Receive cancellation notification;\n\n  |System|\n  :Update booking status to CANCELLED;\n\n  |Customer|\n  :View cancellation confirmation;\n\n  |System|\n  :When customer tries future booking:\n  :Check penalty/foul status;\n\n  if (Penalty exists?) then (Yes)\n    :Show warning message:\n    \&quot;Penalty fee will be added to this booking\&quot;;\n  else (No)\n    :Proceed normally;\n  endif\n\n  stop\n\nelse (No)\n\n  :Display \&quot;Cancellation Denied\&quot;;\n  stop\n\nendif\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="ygYy0BsR_eIQ_32o19Qc-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1151" width="1255" x="570" y="252" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
